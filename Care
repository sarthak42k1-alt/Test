<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MaisonCare - Glow loud, Glow proud</title>

<style>
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: Arial, sans-serif;
}

body {
  background: #fff;
  color: #333;
}

/* HERO */
.hero {
  height: 100vh;
  background: url('https://www.freepik.com/free-photo/happy-beautiful-couple-posing-with-shopping-bags-violet_18348761.htm#fromView=keyword&page=1&position=0&uuid=b7127cc0-cd3b-49cc-97cb-fa3333f7c7ae&query=Shopping') center/cover no-repeat;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.hero-content {
  background: rgba(0,0,0,0.6);
  padding: 30px;
  border-radius: 10px;
  color: #fff;
}

.hero h1 {
  font-size: 3rem;
}

.hero p {
  margin: 10px 0;
}

.btn {
  padding: 12px 20px;
  background: #ff4da6;
  color: #fff;
  border: none;
  cursor: pointer;
  margin-top: 10px;
  border-radius: 5px;
}

/* PRODUCTS */
.products {
  padding: 40px;
}

.carousel {
  display: flex;
  overflow-x: auto;
  gap: 20px;
}

.product {
  min-width: 250px;
  border: 1px solid #ddd;
  padding: 15px;
  border-radius: 10px;
  text-align: center;
}

.product img {
  width: 100%;
  border-radius: 10px;
}

.product button {
  margin-top: 10px;
}

/* CART */
.cart {
  padding: 40px;
  background: #f9f9f9;
}

input, textarea {
  width: 100%;
  padding: 10px;
  margin: 10px 0;
}

/* FOOTER */
footer {
  padding: 20px;
  text-align: center;
}

/* WHATSAPP */
.whatsapp {
  position: fixed;
  bottom: 20px;
  right: 20px;
  background: green;
  color: white;
  padding: 12px;
  border-radius: 50%;
  text-decoration: none;
}
</style>
</head>

<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-content">
    <h1>MaisonCare</h1>
    <p>Glow loud, Glow proud</p>
    <button class="btn" onclick="scrollToProducts()">Shop Now</button>
  </div>
</section>

<!-- PRODUCTS -->
<section class="products" id="products">
  <h2>Our Products</h2>
  <div class="carousel" id="carousel"></div>
</section>

<!-- CART -->
<section class="cart">
  <h2>Your Order</h2>
  <ul id="cartList"></ul>

  <input type="text" id="name" placeholder="Your Name" required>
  <input type="text" id="phone" placeholder="Phone Number" required>

  <button class="btn" onclick="sendOrder()">Send Order</button>
</section>

<footer>
  <p>📍 Nashik | 📞 WhatsApp: 7972647477</p>
</footer>

<a class="whatsapp" href="https://wa.me/917972647477">💬</a>

<!-- EMAILJS -->
<script src="https://cdn.jsdelivr.net/npm/emailjs-com@3/dist/email.min.js"></script>

<script>
emailjs.init("YOUR_PUBLIC_KEY");

/* PRODUCTS DATA */
const products = [
  {name: "Product 1", img: "https://i.ibb.co/KzyYTtKf/Screenshot-2026-03-30-23-02-40-340-edit-com-google-android-googlequicksearchbox.jpg"},
  {name: "Product 2", img: "https://i.ibb.co/sdFpd7s6/Screenshot-2026-03-30-23-03-51-728-edit-com-google-android-googlequicksearchbox.jpg"},
  {name: "Product 3", img: "https://i.ibb.co/TDNvHgpB/Screenshot-2026-03-30-23-04-18-729-edit-com-google-android-googlequicksearchbox.jpg"},
  {name: "Product 4", img: "https://i.ibb.co/7twJkWQB/Screenshot-2026-03-30-23-04-45-180-edit-com-google-android-googlequicksearchbox.jpg"},
  {name: "Product 5", img: "https://i.ibb.co/jkBWZrqH/Screenshot-2026-03-30-23-05-09-987-edit-com-google-android-googlequicksearchbox.jpg"},
  {name: "Product 6", img: "https://i.ibb.co/wFN0bP52/Screenshot-2026-03-30-23-06-08-922-edit-com-google-android-googlequicksearchbox.jpg"},
  {name: "Product 7", img: "https://i.ibb.co/93tZF7dN/Screenshot-2026-03-30-23-06-49-639-edit-com-google-android-googlequicksearchbox.jpg"}
];

const carousel = document.getElementById("carousel");
const cart = [];

products.forEach((p, i) => {
  carousel.innerHTML += `
    <div class="product">
      <img src="${p.img}">
      <h3>${p.name}</h3>
      <button onclick="addToCart(${i})">Add to Cart</button>
    </div>
  `;
});

/* FUNCTIONS */
function scrollToProducts() {
  document.getElementById("products").scrollIntoView({behavior:"smooth"});
}

function addToCart(index) {
  cart.push(products[index].name);
  renderCart();
}

function renderCart() {
  const list = document.getElementById("cartList");
  list.innerHTML = "";
  cart.forEach(item => {
    list.innerHTML += `<li>${item}</li>`;
  });
}

function sendOrder() {
  const name = document.getElementById("name").value;
  const phone = document.getElementById("phone").value;

  if (!name || !phone || cart.length === 0) {
    alert("Please fill all details and add products.");
    return;
  }

  const templateParams = {
    name: name,
    phone: phone,
    order: cart.join(", ")
  };

  emailjs.send("YOUR_SERVICE_ID", "YOUR_TEMPLATE_ID", templateParams)
  .then(() => {
    alert("Order Sent Successfully!");
  }, () => {
    alert("Failed to send order.");
  });
}
</script>

</body>
</html>
